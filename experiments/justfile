default:
    @just --list

sync:
    uv sync

clean-results:
    rm -rf outputs
    rm -rf ../docs/figures/experiments
    rm -f ../docs/experiments.md
    rm -f reports/summary.md

lint:
    uv run ruff check src tests

format:
    uv run ruff format src tests

pipeline-fast-fixture:
    uv run python -m experiments.app suite=synthetic_main setup=baseline matrix.mode=fixture timeout_seconds=8 suite.seed_count=1 "suite.n_attractions=[6,9]" "suite.profiles=[relaxed,tight]"
    uv run python -m experiments.app suite=heuristic_ablation setup=baseline matrix.mode=fixture timeout_seconds=12 suite.seed_count=1 "suite.n_attractions=[6,9]" "suite.profiles=[relaxed,tight]"
    uv run python -m experiments.app suite=bf_reference_small_n setup=window_stress matrix.mode=fixture timeout_seconds=20 suite.seed_count=1 "suite.n_attractions=[6,8]" "suite.profiles=[relaxed,tight]"
    uv run python -m experiments.app suite=handpicked_validation setup=infeasible_sanity matrix.mode=fixture timeout_seconds=20

pipeline-fast-real:
    uv run python -m experiments.app suite=real_reference setup=real_reference matrix.mode=real infra.database_url="postgresql://admin:admin@localhost:5432/Reitti" infra.graphhopper_base_url="http://localhost:8989" timeout_seconds=30 suite.seed_count=1 "suite.n_attractions=[6,9]"

pipeline-fast-both:
    uv run python -m experiments.app suite=synthetic_main setup=baseline matrix.mode=fixture timeout_seconds=8 suite.seed_count=1 "suite.n_attractions=[6,9]" "suite.profiles=[relaxed,tight]"
    uv run python -m experiments.app suite=heuristic_ablation setup=baseline matrix.mode=fixture timeout_seconds=12 suite.seed_count=1 "suite.n_attractions=[6,9]" "suite.profiles=[relaxed,tight]"
    uv run python -m experiments.app suite=bf_reference_small_n setup=window_stress matrix.mode=fixture timeout_seconds=20 suite.seed_count=1 "suite.n_attractions=[6,8]" "suite.profiles=[relaxed,tight]"
    uv run python -m experiments.app suite=handpicked_validation setup=infeasible_sanity matrix.mode=fixture timeout_seconds=20
    uv run python -m experiments.app suite=real_reference setup=real_reference matrix.mode=real infra.database_url="postgresql://admin:admin@localhost:5432/Reitti" infra.graphhopper_base_url="http://localhost:8989" timeout_seconds=30 suite.seed_count=1 "suite.n_attractions=[6,9]"

pipeline-full-fixture:
    uv run python -m experiments.app suite=synthetic_main setup=network_stress matrix.mode=fixture timeout_seconds=60 astar_timeout_seconds=60 suite_timeout_seconds=300

pipeline-full-real:
    uv run python -m experiments.app suite=real_reference setup=real_reference matrix.mode=real infra.database_url="postgresql://admin:admin@localhost:5432/Reitti" infra.graphhopper_base_url="http://localhost:8989" timeout_seconds=90 astar_timeout_seconds=90 suite_timeout_seconds=300

pipeline-full-both:
    uv run python -m experiments.app suite=synthetic_main setup=network_stress matrix.mode=fixture timeout_seconds=60 astar_timeout_seconds=60 suite_timeout_seconds=300
    uv run python -m experiments.app suite=heuristic_ablation setup=baseline matrix.mode=fixture timeout_seconds=60 astar_timeout_seconds=60 suite_timeout_seconds=300
    uv run python -m experiments.app suite=bf_reference_small_n setup=window_stress matrix.mode=fixture timeout_seconds=60 astar_timeout_seconds=60 suite_timeout_seconds=300
    uv run python -m experiments.app suite=handpicked_validation setup=infeasible_sanity matrix.mode=fixture timeout_seconds=60 astar_timeout_seconds=60 suite_timeout_seconds=300
    uv run python -m experiments.app suite=real_reference setup=real_reference matrix.mode=real infra.database_url="postgresql://admin:admin@localhost:5432/Reitti" infra.graphhopper_base_url="http://localhost:8989" timeout_seconds=90 astar_timeout_seconds=90 suite_timeout_seconds=300

pipeline-full-both-parallel:
    uv run python -m experiments.scripts.run_parallel_suites --workers 2 --real-serial

merge-suite-outputs:
    uv run python -m experiments.scripts.merge_suite_outputs

run-fast: (clean-results) (pipeline-fast-both) (figures)
    @echo "Fast full pipeline done (data+plots+docs)."

run-full: (clean-results) (pipeline-full-both) (figures)
    @echo "Full pipeline done (data+plots+docs)."

run-full-parallel: (clean-results) (pipeline-full-both-parallel) (merge-suite-outputs) (figures)
    @echo "Full parallel pipeline done (data+plots+docs)."

run-grid:
    uv run python -m experiments.app suite=synthetic_main setup=baseline matrix.mode=fixture suite.seed_count=1

run-ablation:
    uv run python -m experiments.app suite=heuristic_ablation setup=baseline matrix.mode=fixture suite.seed_count=2

run-boundary:
    uv run python -m experiments.app suite=handpicked_validation setup=infeasible_sanity matrix.mode=fixture

figures:
    uv run python -m experiments.plots.make_all

summary-table:
    uv run python -m experiments.scripts.build_summary_table

docs-report:
    uv run python -m experiments.scripts.build_docs_report

test:
    uv run pytest tests
